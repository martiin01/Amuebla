Terminales no usados en la gramática

   REPETIR


Gramática

    0 $accept: programa $end

    1 programa: siguienteLineaCond bloqueVars bloqueMuebles bloqueHabitaciones

    2 siguienteLin: '\n'
    3             | siguienteLin '\n'

    4 siguienteLineaCond: %empty
    5                   | siguienteLineaCond '\n'

    6 bloqueVars: %empty
    7           | Variables siguienteLin secuenciaVariables

    8 secuenciaVariables: %empty
    9                   | secuenciaVariables definicionVars

   10 definicionVars: ENTERO secuenciaId siguienteLin
   11               | NUMREAL secuenciaId siguienteLin
   12               | LOG secuenciaId siguienteLin
   13               | ENTERO IDVariable ASIGNACION expresion siguienteLin
   14               | NUMREAL IDVariable ASIGNACION expresion siguienteLin
   15               | LOG IDVariable ASIGNACION expresion_bool siguienteLin
   16               | IDVariable ASIGNACION expresion siguienteLin
   17               | IDVariable ASIGNACION expresion_bool siguienteLin
   18               | error siguienteLin

   19 secuenciaId: IDVariable
   20            | secuenciaId COMA IDVariable

   21 bloqueMuebles: MUEBLES siguienteLin secuenciaMuebles

   22 secuenciaMuebles: definicionMueble
   23                 | secuenciaMuebles definicionMueble

   24 definicionMueble: VARIABLEMAYUS ASIGNACIONIGUAL MENOR RECTANGULO COMA expresion COMA expresion COMA COLOR MAYOR siguienteLin
   25                 | VARIABLEMAYUS ASIGNACIONIGUAL MENOR CIRCULO COMA expresion COMA COLOR MAYOR siguienteLin
   26                 | error siguienteLin

   27 bloqueHabitaciones: definicionHabitacion
   28                   | bloqueHabitaciones definicionHabitacion

   29 $@1: %empty

   30 $@2: %empty

   31 definicionHabitacion: INIHABITACION $@1 PARENTIZQ expresion COMA expresion PARENTDER CADENACOMILLAS $@2 DOSPUNTOS siguienteLin secCondiciones FINHABITACION siguienteLin

   32 secuenciaInstrucciones: definicionInstruccion
   33                       | secuenciaInstrucciones definicionInstruccion

   34 definicionInstruccion: SITUAR PARENTIZQ VARIABLEMAYUS COMA expresion COMA expresion PARENTDER siguienteLin
   35                      | PAUSA PARENTIZQ expresion PARENTDER siguienteLin
   36                      | MENSAJE PARENTIZQ CADENACOMILLAS PARENTDER siguienteLin
   37                      | IDVariable ASIGNACION expresion siguienteLin

   38 secCondiciones: defCondicion secCondiciones
   39               | definicionInstruccion secCondiciones
   40               | %empty

   41 defCondicion: condicionSi
   42             | condicionSi condicionSino

   43 $@3: %empty

   44 condicionSi: SI PARENTIZQ expresion_bool PARENTDER $@3 '{' siguienteLineaCond secuenciaInstrucciones '}' siguienteLin

   45 $@4: %empty

   46 condicionSino: SINO $@4 '{' siguienteLineaCond secuenciaInstrucciones '}' siguienteLin

   47 expresion: NUMERO
   48          | REAL
   49          | IDVariable
   50          | '(' expresion ')'
   51          | expresion '+' expresion
   52          | expresion '-' expresion
   53          | expresion '*' expresion
   54          | expresion '/' expresion
   55          | expresion '%' expresion
   56          | '-' expresion

   57 expresion_bool: FALSE
   58               | TRUE
   59               | expresion MAYOR expresion
   60               | expresion MENOR expresion
   61               | expresion MAYOR_IGUAL expresion
   62               | expresion MENOR_IGUAL expresion
   63               | expresion IGUAL expresion
   64               | expresion DISTINTO expresion
   65               | expresion_bool IGUAL expresion_bool
   66               | expresion_bool DISTINTO expresion_bool
   67               | expresion_bool OR expresion_bool
   68               | expresion_bool AND expresion_bool
   69               | NOT expresion_bool
   70               | '(' expresion_bool ')'


